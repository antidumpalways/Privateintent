# ============================================================================
# PRIVATE INTENT — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
#
#   cp .env.example .env
# ============================================================================

# ─── Database ──────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Example: postgresql://postgres:password@localhost:5432/private_intent
DATABASE_URL=postgresql://postgres@localhost:5432/private_intent

# ─── Ports ─────────────────────────────────────────────────────────────────

# API server port (default: 8080)
PORT=8080
API_PORT=8080
API_HOST=0.0.0.0

# ─── CORS ──────────────────────────────────────────────────────────────────

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── AI Features (Anthropic Claude) ────────────────────────────────────────
# Required for: NL intent parsing, AI Solver, Dispute Resolution
# Get your API key at https://console.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=

# ─── Escrow Contract (Ethereum Sepolia) ────────────────────────────────────
# Deployed PrivateIntentEscrow.sol on Sepolia
ESCROW_CONTRACT_ADDRESS=
ETH_ESCROW_CONTRACT_ADDRESS=
ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# ─── Solana Escrow (Anchor Program) ────────────────────────────────────────
# Anchor program deployed on Solana Devnet
SOLANA_ESCROW_PROGRAM_ID=
SOLANA_ESCROW_DEPLOYER_KEY=[]

# ─── Solver ────────────────────────────────────────────────────────────────
# ETH testnet solver wallet private key
SOLVER_PK=0x...
ETH_SOLVER_PRIVATE_KEY=0x...

# ─── Sentinel ──────────────────────────────────────────────────────────────
SENTINEL_ADDRESS=0x...

# ─── Solana Sentinel Keypair ───────────────────────────────────────────────────
# The sentinel keypair is used for escrow PDAs and on-chain SOL broadcasts.
# On first boot, the server generates a fresh keypair and prints the pubkey.
# Copy the output of `cat /tmp/prism-sentinel-keypair.json` as the array below
# to persist it across restarts (avoids re-funding every time).

# Sentinel's secret key as a JSON number array (64 elements)
SOLANA_SECRET_KEY_ARRAY=[]

# Sentinel's public key (base58) — must match the array above
SOLANA_DEVNET_PUBKEY=

# ─── Live Solver ETH Wallet (Optional) ────────────────────────────────────────
# Required for real ETH Sepolia / BASE / ARB testnet delivery.
# Generate a fresh wallet or use an existing testnet wallet.
ETH_SOLVER_PRIVATE_KEY=0x...

# ─── FHE Master Encryption Key (Optional) ────────────────────────────────────
# 64 hex characters (32 bytes). Auto-derived from DATABASE_URL hash if not set.
# Setting it explicitly ensures encrypted audit logs survive DB resets.
MASTER_ENCRYPT_KEY=<64-hex-chars>

# ─── PostgreSQL (individual fields for app code) ───────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=privateintent
POSTGRES_USER=privateintent
POSTGRES_PASSWORD=privateintent123