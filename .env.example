# ============================================================================
# PRIVATE INTENT — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
#
#   cp .env.example .env
# ============================================================================

# ─── Database ──────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://privateintent:privateintent123@localhost:5432/privateintent

# ─── Ports ─────────────────────────────────────────────────────────────────

PORT=8080
API_PORT=8080
API_HOST=0.0.0.0

# ─── CORS ──────────────────────────────────────────────────────────────────

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── AI Features (Anthropic Claude) ────────────────────────────────────────
# Required for: NL intent parsing, AI Solver, Dispute Resolution
# Get your API key at https://console.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-xxx

# ─── Escrow Contract (Ethereum Sepolia) ────────────────────────────────────
# Deployed PrivateIntentEscrow.sol on Sepolia
ESCROW_CONTRACT_ADDRESS=0x47D8A17167082B68Bf7f2004754BBC3A43b5Bd9A
ETH_ESCROW_CONTRACT_ADDRESS=0x47D8A17167082B68Bf7f2004754BBC3A43b5Bd9A
ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# ─── Solana Escrow (Anchor Program) ────────────────────────────────────────
# Anchor program deployed on Solana Devnet
SOLANA_ESCROW_PROGRAM_ID=GJbT5jcR38MzkmsCDrVWrjq2Bvg961CUkMnvUq7naqmq
SOLANA_ESCROW_DEPLOYER_KEY=[]

# ─── Solver / Live Delivery ────────────────────────────────────────────────
# ETH testnet solver wallet private key (for real Sepolia/BASE/ARB tx)
# Both names are supported — code reads SOLVER_ETH_PRIVATE_KEY
ETH_SOLVER_PRIVATE_KEY=0x...
SOLVER_ETH_PRIVATE_KEY=0x...
SOLVER_PK=0x...
DEPLOYER_PRIVATE_KEY=0x...

# ─── Sentinel ──────────────────────────────────────────────────────────────
SENTINEL_ADDRESS=0x...
SENTINEL_ETH_ADDRESS=0xFe4957467b528e6E4F2712DCD3C2D4BaB2CDb6AA

# ─── Solana Sentinel Keypair ───────────────────────────────────────────────
# The sentinel keypair is used for escrow PDAs and on-chain SOL broadcasts.
# On first boot, the server generates a fresh keypair and prints the pubkey.
# Copy the output of `cat /tmp/prism-sentinel-keypair.json` as the array below
# to persist it across restarts (avoids re-funding every time).
SOLANA_SECRET_KEY_ARRAY=[]
SOLANA_DEVNET_PUBKEY=9xPwjf2dmafdxhnyZeAaVQpYWxH4Kn1N9XeeLQpnkttu

# ─── FHE Master Encryption Key (Optional) ──────────────────────────────────
# 64 hex characters (32 bytes). Auto-derived from DATABASE_URL hash if not set.
# Setting it explicitly ensures encrypted audit logs survive DB resets.
MASTER_ENCRYPT_KEY=<64-hex-chars>

# ─── PostgreSQL (individual fields) ────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=privateintent
POSTGRES_USER=privateintent
POSTGRES_PASSWORD=

# ─── Strict Mode (Production Safety) ─────────────────────────────────────
# When true: disables ALL simulation/local fallbacks.
# Ika MPC failure → request fails (no sim).
# Encrypt FHE failure → request fails (no local AES fallback).
# Live delivery failure → status set to "failed" (no sim_* txHash).
# ALWAYS set to "true" before going to production!
STRICT_MODE=false